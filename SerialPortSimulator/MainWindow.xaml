<Window x:Class="SerialPortSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="串口助手 — 下位机模拟器"
        Height="720"
        Width="960"
        MinHeight="560"
        MinWidth="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="虚拟串口联调说明" Click="Help_Click"/>
            </MenuItem>
        </Menu>

        <DockPanel Margin="10">
            <!-- 连接栏 -->
            <Border DockPanel.Dock="Top" Padding="10" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="COM口" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}"/>
                    <TextBlock Grid.Column="2" Text="波特率" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding BaudRate}"/>
                    <TextBlock Grid.Column="4" Text="{Binding ConnectionStatusLabel}" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
                    <Button Grid.Column="5" Content="刷新" Command="{Binding RefreshPortsCommand}" Padding="12,5" Margin="8,0,0,0"/>
                    <Button Grid.Column="6" Content="{Binding ConnectButtonText}" Command="{Binding ConnectCommand}" Padding="16,5" Margin="8,0,0,0" MinWidth="80"/>
                </Grid>
            </Border>

            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusText}" Foreground="#555" Margin="0,0,0,8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                </Grid.ColumnDefinitions>

                <!-- 左：数据/日志生成 -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="测试数据生成 (DATA)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Border Padding="10" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="4" Background="#E3F2FD" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Content="自动发送 DATA" IsChecked="{Binding AutoData}" Margin="0,0,0,6"/>
                                <CheckBox Content="三通道 (X/Y/Z 模拟)" IsChecked="{Binding ThreeChannels}" Margin="0,0,0,6"/>
                                <CheckBox Content="使用 DATB 二进制 (count+大端 uint16+LF)" IsChecked="{Binding UseDatbBinary}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="间隔(ms)" VerticalAlignment="Center" Width="70"/>
                                    <TextBox Text="{Binding DataIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                </StackPanel>
                                <Button Content="立即发送一条 DATA" Command="{Binding SendDataOnceCommand}" Padding="10,5" HorizontalAlignment="Left"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#1565C0" Margin="0,8,0,0" TextWrapping="Wrap">
                                    <Run Text="ASCII 示例: DATA:16384,16402,16390"/>
                                    <LineBreak/>
                                    <Run Text="DATB 示例: 44 41 54 42 3A 03 40 00 40 02 40 06 0A"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="测试日志生成 (LOG)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Border Padding="10" BorderBrush="#FFCC80" BorderThickness="1" CornerRadius="4" Background="#FFF3E0" Margin="0,0,0,12">
                            <StackPanel>
                                <CheckBox Content="自动发送 LOG" IsChecked="{Binding AutoLog}" Margin="0,0,0,6"/>
                                <CheckBox Content="等级用首字节 (0~4)" IsChecked="{Binding LogUseLevelByte}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="间隔(ms)" VerticalAlignment="Center" Width="70"/>
                                    <TextBox Text="{Binding LogIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                </StackPanel>
                                <Button Content="立即发送一条 LOG" Command="{Binding SendLogOnceCommand}" Padding="10,5" HorizontalAlignment="Left"/>
                                <TextBlock Text="示例: LOG:1,IMU 采样正常  或  LOG:[0x02]告警" FontFamily="Consolas" FontSize="11" Foreground="#E65100" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="手动发送（文本行）" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ManualSend, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Padding="6,4"/>
                            <Button Grid.Column="1" Content="发送" Command="{Binding SendManualCommand}" Padding="14,5" Margin="8,0,0,0"/>
                        </Grid>

                        <TextBlock Text="任意数据发送" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Border Padding="10" BorderBrush="#CE93D8" BorderThickness="1" CornerRadius="4" Background="#F3E5F5" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBox Text="{Binding RawSend, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Padding="6,4" MinHeight="48" TextWrapping="Wrap" AcceptsReturn="True"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="HEX 模式" IsChecked="{Binding RawSendAsHex}" Margin="0,0,16,0"/>
                                    <CheckBox Content="末尾加换行 (0x0A)" IsChecked="{Binding RawSendAppendNewline}"/>
                                </StackPanel>
                                <Button Content="发送原始数据" Command="{Binding SendRawCommand}" Padding="10,5" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                <TextBlock Text="HEX 示例: 44 41 54 41 3A 31 0A   文本示例: hello" FontFamily="Consolas" FontSize="11" Foreground="#6A1B9A" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <GridSplitter Grid.Column="1" Width="8"/>

                <!-- 右：CMD 回复 + 串口监控 -->
                <DockPanel Grid.Column="2">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="命令自动回复 (AT+→OK/ERR / CMD→ACK)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                        <CheckBox Content="收到 AT+/CMD 后自动回复文本行或 ACK 帧" IsChecked="{Binding AutoAck}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="恢复默认规则" Command="{Binding ResetRulesCommand}" Padding="10,4"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding CmdRules}" AutoGenerateColumns="False" CanUserAddRows="True"
                                  HeadersVisibility="Column" Height="160" Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="50"/>
                                <DataGridTextColumn Header="Opcode" Binding="{Binding Opcode}" Width="60"/>
                                <DataGridTextColumn Header="命令关键字" Binding="{Binding CommandKeyword, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="URC（先发）" Binding="{Binding UrcLine, UpdateSourceTrigger=PropertyChanged}" Width="1.2*"/>
                                <DataGridCheckBoxColumn Header="ACK" Binding="{Binding UseBinaryAck}" Width="55"/>
                                <DataGridTextColumn Header="文本回复" Binding="{Binding AckResponse, UpdateSourceTrigger=PropertyChanged}" Width="1.2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="未匹配：AT+→OK …；CMD→ACK status=OK" Foreground="#666" FontSize="11"/>
                    </StackPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,8,0,6">
                            <TextBlock Text="串口监控" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="{Binding MonitorDisplayModeLabel, StringFormat=显示: {0}}"
                                    Command="{Binding ToggleMonitorDisplayCommand}" Margin="12,0,0,0" Padding="10,4"/>
                            <Button Content="清空" Command="{Binding ClearLogCommand}" Margin="8,0,0,0" Padding="10,4"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding TrafficLog}" FontFamily="Consolas" FontSize="12"
                                 BorderBrush="#DDD" Background="#FAFAFA"/>
                    </DockPanel>
                </DockPanel>
            </Grid>
        </DockPanel>
    </DockPanel>
</Window>
