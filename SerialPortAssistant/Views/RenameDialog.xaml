<Window x:Class="SerialPortAssistant.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16" MinWidth="320">
        <TextBlock x:Name="PromptText" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" Padding="6,4" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" IsDefault="True" Click="Ok_Click" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Padding="16,6"/>
        </StackPanel>
    </StackPanel>
</Window>
