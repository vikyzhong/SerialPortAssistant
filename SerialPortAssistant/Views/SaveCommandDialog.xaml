<Window x:Class="SerialPortAssistant.Views.SaveCommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保存为新命令"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16" MinWidth="360">
        <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"
                   Text="将写入命令码表。Opcode、名称、文本别名须唯一，且与当前双帧内容一致。"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="88"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Opcode" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="OpcodeBox" FontFamily="Consolas" Padding="6,4" Margin="0,6"/>
            <TextBlock Grid.Row="1" Text="显示名称" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="NameBox" Padding="6,4" Margin="0,6"/>
            <TextBlock Grid.Row="2" Text="文本别名" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="AliasBox" FontFamily="Consolas" Padding="6,4" Margin="0,6"/>
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="保存" IsDefault="True" Click="Ok_Click" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Padding="16,6"/>
        </StackPanel>
    </StackPanel>
</Window>
