<UserControl x:Class="SerialPortAssistant.Views.LightweightChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="120"
             MinWidth="160"
             Background="White"
             Focusable="True">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Canvas x:Name="YTickCanvas" Grid.Column="0" ClipToBounds="True"/>
            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" Background="White">
                <Grid>
                    <Canvas x:Name="PlotCanvas" ClipToBounds="True"
                            Background="Transparent"
                            MouseWheel="PlotCanvas_MouseWheel"
                            PreviewMouseDown="PlotCanvas_PreviewMouseDown"
                            MouseMove="PlotCanvas_MouseMove"
                            PreviewMouseUp="PlotCanvas_PreviewMouseUp"
                            MouseLeave="PlotCanvas_MouseLeave"/>
                    <StackPanel x:Name="LegendPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="8,6,8,0"
                                Background="#F8FFFFFF"/>
                </Grid>
            </Border>
        </Grid>
        <Canvas x:Name="XTickCanvas" Grid.Row="1" Margin="52,2,0,0" Height="22"/>
    </Grid>
</UserControl>
