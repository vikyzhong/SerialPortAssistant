<Window x:Class="SerialPortAssistant.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使用说明 - 串口助手"
        Height="820"
        Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="HelpBodyText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="LineHeight" Value="24"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
        <Style x:Key="HelpSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
        </Style>
        <Style x:Key="HelpCaseTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1565C0"/>
        </Style>
        <Style x:Key="HelpMonoLine" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="HelpCaseBorder" TargetType="Border">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">
        <Button DockPanel.Dock="Bottom" Content="关闭" IsDefault="True" Click="Close_Click"
                HorizontalAlignment="Right" Padding="20,8" Margin="0,12,0,0" FontSize="13"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="串口助手 使用说明" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,12">
                    下文为界面操作与按类型分组的联调案例（含完整 HEX）。各通道帧结构、判头与解析顺序见「帮助 → 协议总览」。
                </TextBlock>

                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,16">
                    未识别为协议类型的行：默认不进日志（可勾选「显示 RAW」）；原始字节请查看底部「串口监控」。通道名（默认 X/Y/Z）在「设置 → 数据通道」修改。
                </TextBlock>

                <TextBlock Text="案例" Style="{StaticResource HelpSectionTitle}" Margin="0,0,0,8"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,14">
                    下列各案例单独成段；HEX 均从该帧第一个字节（前缀首字节）起完整列出，不承接上一案例末尾。
                </TextBlock>

                <TextBlock Text="1. 连接串口" Style="{StaticResource HelpSectionTitle}" Margin="0,0,0,6"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,8">
                    选择 COM 口与波特率（最高 1M），第二行可设流控（Handshake）、DTR、RTS（已连接时可改 DTR/RTS；用于复位、Bootloader 等，以硬件手册为准）。点击「打开」；绿色圆点 = 已连接。
                    曲线区「导出 CSV」可保存当前缓冲区内采样点（Index + 各通道列，UTF-8）。
                    命令区「定时」：填间隔 ms 后点「开始」，按当前 AT+/CMD 帧循环发送，点「停止」或断开串口结束。
                    「历史命令」下拉：选中后载入；可解析为 AT+/CMD 则还原双帧，否则原样填入发送内容框（可编辑后发送）。仅手动「发送」写入历史。
                </TextBlock>

                <TextBlock Text="2. DATA" Style="{StaticResource HelpSectionTitle}"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    帧结构见「帮助 → 协议总览」。下列 HEX 每例均从 44 41 54 41 3A 起算。
                </TextBlock>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#E3F2FD">
                    <StackPanel>
                        <TextBlock Text="【案例 A】三轴加速度" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：DATA:16384,16402,16390"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：44 41 54 41 3A 31 36 33 38 34 2C 31 36 34 30 32 2C 31 36 33 39 30 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E3F2FD">
                    <StackPanel>
                        <TextBlock Text="【案例 B】单路" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：DATA:512"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：44 41 54 41 3A 35 31 32 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E3F2FD" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="【案例 C】联调示例" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：DATA:1000,2000,3000"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：44 41 54 41 3A 31 30 30 30 2C 32 30 30 30 2C 33 30 30 30 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E1F5FE" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="【案例 A】MCU 按 HEX 发送（独立一帧）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock FontFamily="Consolas" FontSize="12.5" LineHeight="22" TextWrapping="Wrap" Margin="0,6,0,0">
                            const uint8_t tx[] = {
                                0x44,0x41,0x54,0x41,0x3A,
                                0x31,0x36,0x33,0x38,0x34,
                                0x2C,
                                0x31,0x36,0x34,0x30,0x32,
                                0x2C,
                                0x31,0x36,0x33,0x39,0x30,
                                0x0A
                            };
                            uart_write(tx, sizeof(tx));
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="2.1 DATB" Style="{StaticResource HelpSectionTitle}"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    帧结构见「帮助 → 协议总览」。下列 HEX 每例均从 44 41 54 42 3A 起算。
                </TextBlock>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#E8F5E9">
                    <StackPanel>
                        <TextBlock Text="【案例 D】三通道 DATB" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="数值：16384, 16402, 16390（与 ASCII 案例 A 相同）"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="count = 0x03"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：44 41 54 42 3A 03 40 00 40 02 40 06 0A"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="帧长 13 字节（ASCII 三通道约 25 字节）"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E8F5E9">
                    <StackPanel>
                        <TextBlock Text="【案例 E】单路 DATB" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="数值：512，count = 0x01"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：44 41 54 42 3A 01 02 00 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E8F5E9" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="【案例 F】MCU 组包（可变路数）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock FontFamily="Consolas" FontSize="12.5" LineHeight="22" TextWrapping="Wrap" Margin="0,6,0,0">
                            void uart_send_datb(const uint16_t *v, uint8_t count) {
                                uint8_t tx[16];
                                uint8_t n = 0;
                                const char p[] = "DATB:";
                                memcpy(tx, p, 5); n = 5;
                                tx[n++] = count;
                                for (uint8_t i = 0; i &lt; count; i++) {
                                    tx[n++] = (uint8_t)(v[i] >> 8);
                                    tx[n++] = (uint8_t)(v[i] &amp; 0xFF);
                                }
                                tx[n++] = '\n';
                                uart_write(tx, n);
                            }
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="3. LOG" Style="{StaticResource HelpSectionTitle}"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    帧结构见「帮助 → 协议总览」。下列 HEX 每例均从 4C 4F 47 3A 起算。
                </TextBlock>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFFDE7" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="日志面板显示格式" FontWeight="SemiBold" Foreground="#F57F17" Margin="0,0,0,6"/>
                        <TextBlock FontFamily="Consolas" FontSize="12.5" LineHeight="22" TextWrapping="Wrap">
                            标准 LOG 行：[HH:mm:ss.fff] [等级ID:等级名] 消息正文
                            RAW 行（需勾选）：[HH:mm:ss.fff] [RAW] 未识别文本
                        </TextBlock>
                        <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,8,0,0" FontSize="12">
                            说明：DATA 只更新曲线，不进日志；OK/ERR/+URC 与 ACK 进「命令回传」区；AT+ 从设备上行时日志可能显示 [AT-RX]。
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF3E0">
                    <StackPanel>
                        <TextBlock Text="【案例 A】二进制 INFO(0x01) + 英文" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:[0x01]IMU started"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 01 49 4D 55 20 73 74 61 72 74 65 64 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF3E0">
                    <StackPanel>
                        <TextBlock Text="【案例 B】二进制 WARN(0x02)" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:[0x02]temp high 45C"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 02 74 65 6D 70 20 68 69 67 68 20 34 35 43 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF3E0">
                    <StackPanel>
                        <TextBlock Text="【案例 C】二进制 ERROR(0x03)" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:[0x03]sensor offline"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 03 73 65 6E 73 6F 72 20 6F 66 66 6C 69 6E 65 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF3E0">
                    <StackPanel>
                        <TextBlock Text="【案例 D】ASCII 等级字符 '1' (0x31)" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:1,IMU started"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 31 2C 49 4D 55 20 73 74 61 72 74 65 64 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF3E0" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="【案例 E】中文 UTF-8 + 二进制 INFO" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:[0x01]系统启动"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 01 E7 B3 BB E7 BB 9F E5 90 AF E5 8A A8 0A"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="3.1 日志面板显示案例（与协议案例对应）" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,8" Foreground="#E65100"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    下列为收到上述 LOG 帧后，右侧日志区的实际显示（时间戳为示例）。等级名可在「设置 → 协议与日志配置」中修改。
                </TextBlock>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="【面板案例 A】对应协议案例 A（INFO）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="日志显示：[12:34:56.789] [1:INFO] IMU started"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="需勾选等级：INFO"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="【面板案例 B】对应协议案例 B（WARN）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="日志显示：[12:34:57.012] [2:WARN] temp high 45C"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="需勾选等级：WARN"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="【面板案例 C】对应协议案例 D（ASCII 等级字符）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="日志显示：[12:34:57.200] [1:INFO] IMU started"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="说明：LOG:1,IMU started 与二进制 0x01 等等价，面板显示相同"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="【面板案例 D】对应协议案例 E（中文）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="日志显示：[12:34:57.456] [1:INFO] 系统启动"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#EFEBE9">
                    <StackPanel>
                        <TextBlock Text="【面板案例 E】等级过滤" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="取消勾选 WARN 时，协议案例 B 的日志行不再显示"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="「全选 / 全不选」可快速切换；过滤设置会自动保存"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#EFEBE9" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="【面板案例 F】RAW 原始行（需勾选「显示 RAW 原始行」）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="下位机发送：hello（无协议前缀，HEX：68 65 6C 6C 6F 0A）"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="勾选 RAW 后日志显示：[12:34:58.100] [RAW] hello"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="不勾选 RAW：日志区不显示；串口监控仍显示 RX← 68 65 6C 6C 6F"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#EFEBE9" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="【面板案例 G】LOG 格式错误 → RAW" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="下位机发送：LOG:badlevel,消息（等级字节无效）"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="HEX（从头）：4C 4F 47 3A 62 61 64 6C 65 76 65 6C 2C E6 B6 88 E6 81 AF 0A"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="勾选 RAW 后日志显示：[12:34:58.300] [RAW] LOG:badlevel,消息"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#FFF8E1" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="【案例 A】MCU 按 HEX 发送（独立一帧）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock FontFamily="Consolas" FontSize="12.5" LineHeight="22" TextWrapping="Wrap" Margin="0,6,0,0">
                            const uint8_t tx[] = {
                                0x4C,0x4F,0x47,0x3A,
                                0x01,
                                'I','M','U',' ','s','t','a','r','t','e','d',
                                0x0A
                            };
                            uart_write(tx, sizeof(tx));
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="4. AT+ / CMD / 文本回传 / ACK" Style="{StaticResource HelpSectionTitle}"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    命令与回传对称关系见「帮助 → 协议总览」。主界面：选命令或点快捷按钮 → 编辑 AT+/CMD 帧 → 勾选「用此格式发送」→「保存为新命令」写入命令码表。
                </TextBlock>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#F1F8E9" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="【案例 G】二进制复位 CMD / ACK" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="主机 HEX 输入：01（opcode=复位）"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX TX：43 4D 44 01 01 0A"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="下位机 ACK：opcode=01, status=00(OK)"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX RX：41 43 4B 02 01 00 0A"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="回传区显示：OK #01 复位"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#E8F5E9">
                    <StackPanel>
                        <TextBlock Text="【案例 A】读版本 — 主机下发 AT+GMR" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：AT+GMR"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX TX（从头）：41 54 2B 47 4D 52 0D 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E8F5E9">
                    <StackPanel>
                        <TextBlock Text="【案例 A】读版本 — 下位机回复" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：SerialPortSimulator v1.0.0-sim"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：OK"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#E8F5E9" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="【案例 A】MCU 文本回传（独立一帧）" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock FontFamily="Consolas" FontSize="12.5" LineHeight="22" TextWrapping="Wrap" Margin="0,6,0,0">
                            const uint8_t ver[] = {
                                'S','e','r','i','a','l','P','o','r','t','S','i','m',' ',
                                'v','1','.','0','.','0', 0x0A
                            };
                            uart_write(ver, sizeof(ver));
                            const uint8_t ok[] = { 'O','K', 0x0A };
                            uart_write(ok, sizeof(ok));
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="5. 完整联调时序（每步独立一帧，HEX 从头）" Style="{StaticResource HelpSectionTitle}"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    按顺序发送；每一步的 HEX 均从该帧前缀首字节起，不拼接上一帧尾部。
                </TextBlock>

                <Border Style="{StaticResource HelpCaseBorder}" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="步骤 ① DATA" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：DATA:1000,2000,3000"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：44 41 54 41 3A 31 30 30 30 2C 32 30 30 30 2C 33 30 30 30 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="步骤 ② LOG" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:[0x01]system boot"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 01 73 79 73 74 65 6D 20 62 6F 6F 74 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="步骤 ③ LOG" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：LOG:[0x02]temp 45C"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX（从头）：4C 4F 47 3A 02 74 65 6D 70 20 34 35 43 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="步骤 ④ 主机发 AT+" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：AT+GMR"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}"
                                   Text="HEX TX（从头）：41 54 2B 47 4D 52 0D 0A"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#F5F5F5" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="步骤 ⑤ 下位机回版本 + OK" Style="{StaticResource HelpCaseTitle}"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：SerialPortSimulator v1.0.0-sim"/>
                        <TextBlock Style="{StaticResource HelpMonoLine}" Text="文本：OK"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="6. ASCII 速查" Style="{StaticResource HelpSectionTitle}"/>
                <Border Style="{StaticResource HelpCaseBorder}" Background="#F5F5F5" Margin="0,0,0,14">
                    <TextBlock FontFamily="Consolas" FontSize="12.5" LineHeight="22" TextWrapping="Wrap">
                        '0'~'9' = 30~39    ',' = 2C    ' ' = 20    '_' = 5F
                        'A'~'Z' = 41~5A    'a'~'z' = 61~7A    ':' = 3A
                        '\n' = 0A    '\r' = 0D
                    </TextBlock>
                </Border>

                <TextBlock Text="7. 串口监控、日志与配置" Style="{StaticResource HelpSectionTitle}"/>
                <TextBlock Style="{StaticResource HelpBodyText}" Margin="0,0,0,10">
                    底部「串口监控」：显示原始收发字节（HEX/字符串），每条以换行结束的报文单独一行，用于确认链路是否正常。
                    右侧「日志」：显示 LOG 等级行；勾选「显示 RAW 原始行」才显示未识别文本（见 3.1 面板案例 F/G）。
                    「设置 → 协议与日志配置」可改前缀、等级名与颜色；「显示 RAW」与等级过滤保存在 %AppData%\SerialPortAssistant\settings.json。
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
