<Window x:Class="SerialPortAssistant.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 - 串口助手"
        Height="280"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="串口助手" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center" Margin="0,8,0,20" Foreground="#666" FontSize="13"/>

            <TextBlock Text="多路 uint16 数据曲线、协议日志、AT+ 命令与串口监控工具。" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" Foreground="#444" LineHeight="22"/>

            <Border Margin="0,20,0,0" Padding="14" Background="#F5F5F5" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="作者联系方式" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock FontSize="14">
                        <Run Text="邮箱："/>
                        <Hyperlink NavigateUri="mailto:zhongvv@163.com" RequestNavigate="EmailLink_RequestNavigate">
                            zhongvv@163.com
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button Content="关闭" IsDefault="True" Click="Close_Click" HorizontalAlignment="Center"
                    Margin="0,20,0,0" Padding="28,8" MinWidth="100"/>
        </StackPanel>
    </Border>
</Window>
