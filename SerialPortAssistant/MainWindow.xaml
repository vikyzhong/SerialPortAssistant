<Window x:Class="SerialPortAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:helpers="clr-namespace:SerialPortAssistant.Helpers"
        Title="串口助手"
        Height="820"
        Width="1200"
        MinHeight="600"
        MinWidth="900">
    <Window.Resources>
        <helpers:HexToBrushConverter x:Key="HexToBrush"/>
        <Style x:Key="RowGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Height" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ResizeDirection" Value="Rows"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="ShowsPreview" Value="False"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="SizeNS"/>
        </Style>
        <Style x:Key="ColumnGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="ResizeDirection" Value="Columns"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="ShowsPreview" Value="False"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="SizeWE"/>
        </Style>
        <Style x:Key="ConnectionBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HorizontalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Height" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ResizeDirection" Value="Rows"/>
            <Setter Property="ShowsPreview" Value="False"/>
            <Setter Property="Background" Value="#BDBDBD"/>
            <Setter Property="Cursor" Value="SizeNS"/>
        </Style>
        <Style x:Key="VerticalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="ResizeDirection" Value="Columns"/>
            <Setter Property="ShowsPreview" Value="False"/>
            <Setter Property="Background" Value="#BDBDBD"/>
            <Setter Property="Cursor" Value="SizeWE"/>
        </Style>
        <Style x:Key="CmdPrefixLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CmdInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MaxHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="CmdWireRadioStyle" TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style x:Key="CmdPanelBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
        <Style x:Key="CmdHexPreviewStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="MaxHeight" Value="72"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="设置(_S)">
                <MenuItem Header="协议与日志配置..." Command="{Binding OpenSettingsCommand}" InputGestureText="Ctrl+,"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="使用说明" Command="{Binding OpenHelpCommand}" InputGestureText="F1"/>
                <MenuItem Header="协议总览" Command="{Binding OpenProtocolOverviewCommand}"/>
                <MenuItem Header="关于..." Command="{Binding OpenAboutCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="220" MinHeight="120"/>
            </Grid.RowDefinitions>

        <!-- 顶部：串口连接 -->
        <Border Grid.Row="0" Padding="8" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="COM口" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="PortCombo" Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="波特率" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <ComboBox x:Name="BaudCombo" Grid.Row="0" Grid.Column="3" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaudRate}"/>
                <CheckBox Grid.Row="0" Grid.Column="4" Content="自定义" IsChecked="{Binding UseCustomBaudRate}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding CustomBaudRate, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>

                <TextBlock Grid.Row="0" Grid.Column="6" Text="校验" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <ComboBox x:Name="ParityCombo" Grid.Row="0" Grid.Column="7" ItemsSource="{Binding ParityOptions}" SelectedItem="{Binding Parity}"/>

                <TextBlock Grid.Row="0" Grid.Column="8" Text="数据位" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <ComboBox x:Name="DataBitsCombo" Grid.Row="0" Grid.Column="9" ItemsSource="{Binding DataBitsOptions}" SelectedItem="{Binding DataBits}"/>

                <TextBlock Grid.Row="0" Grid.Column="10" Text="停止位" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <ComboBox x:Name="StopBitsCombo" Grid.Row="0" Grid.Column="11" ItemsSource="{Binding StopBitsOptions}" SelectedItem="{Binding StopBits}"/>

                <!-- 连接状态标志 -->
                <Border Grid.Row="0" Grid.Column="12" Style="{StaticResource ConnectionBadgeStyle}" HorizontalAlignment="Left" Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="14" Height="14" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#9E9E9E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatusLabel}" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#757575"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ConnectionDetailText}" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Button Grid.Row="0" Grid.Column="13" Content="刷新端口" Command="{Binding RefreshPortsCommand}" Padding="10,4" Margin="8,0,0,0"/>
                <Button Grid.Row="0" Grid.Column="14" Content="{Binding ConnectButtonText}" Command="{Binding ConnectCommand}" Padding="14,4" Margin="8,0,0,0" MinWidth="72">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#1976D2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="#FF5722"/>
                                    <Setter Property="BorderBrush" Value="#E64A19"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="流控" VerticalAlignment="Center" Margin="0,8,6,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                          ItemsSource="{Binding HandshakeOptions}" SelectedItem="{Binding Handshake}"
                          ToolTip="硬件流控；打开串口时生效，已连接时可即时修改"/>
                <CheckBox Grid.Row="1" Grid.Column="3" Content="DTR" IsChecked="{Binding DtrEnable}" VerticalAlignment="Center" Margin="12,8,0,0"
                          ToolTip="数据终端就绪；部分板卡接复位/Boot 脚，请对照硬件手册"/>
                <CheckBox Grid.Row="1" Grid.Column="4" Content="RTS" IsChecked="{Binding RtsEnable}" VerticalAlignment="Center" Margin="8,8,0,0"
                          ToolTip="请求发送；可与 CTS 配合做硬件流控"/>
            </Grid>
        </Border>

        <!-- 中部：左数据曲线 | 右日志 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="320"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="2*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="数据显示（UINT16）" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button x:Name="PauseButton" Content="暂停" Click="PauseButton_Click" Margin="12,0,0,0" Padding="10,4"/>
                    <Button Content="清空曲线" Command="{Binding Chart.ClearCommand}" Margin="8,0,0,0" Padding="10,4"/>
                    <Button Content="导出 CSV" Command="{Binding Chart.ExportCsvCommand}" Margin="8,0,0,0" Padding="10,4"
                            ToolTip="导出当前缓冲区内曲线数据（最多 10 万点/段）"/>
                </StackPanel>
                <TextBlock x:Name="StatsText" DockPanel.Dock="Top" Margin="0,0,0,4" Foreground="#555" TextWrapping="Wrap"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="PlotTitleLabel" Grid.Row="0"
                               Text="数据显示（UINT16）"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,0,0,4"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PlotYAxisLabel" Grid.Column="0"
                                   Text="Y轴（0-65535）"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   TextAlignment="Center">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                        <scott:WpfPlot x:Name="DataPlot" Grid.Column="1"/>
                    </Grid>
                    <TextBlock x:Name="PlotXAxisLabel" Grid.Row="2"
                               Text="X轴"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>

            <DockPanel Grid.Column="2" Margin="8,0,0,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="日志" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox Content="自动滚动" IsChecked="{Binding Log.AutoScroll}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    <Button Content="全选" Command="{Binding Log.SelectAllLevelsCommand}" Margin="12,0,0,0" Padding="8,4"/>
                    <Button Content="全不选" Command="{Binding Log.DeselectAllLevelsCommand}" Margin="6,0,0,0" Padding="8,4"/>
                    <Button Content="清空" Command="{Binding Log.ClearCommand}" Margin="8,0,0,0" Padding="10,4"/>
                    <Button Content="保存" Command="{Binding Log.SaveCommand}" Margin="8,0,0,0" Padding="10,4"/>
                    <Button Content="复制" Command="{Binding Log.CopyCommand}" Margin="8,0,0,0" Padding="10,4"/>
                </StackPanel>
                <Border DockPanel.Dock="Top" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                        Padding="8,6" Margin="0,0,0,6" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="显示等级 (勾选过滤)" FontSize="11" Foreground="#666" Margin="0,0,0,6"/>
                        <CheckBox Content="显示 RAW 原始行" IsChecked="{Binding Log.ShowRawLog}" Margin="0,0,0,8"
                                  ToolTip="未匹配 DATA/LOG/AT 回传等的原始文本；关闭后请查看底部串口监控"/>
                        <ItemsControl ItemsSource="{Binding Log.LevelFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsVisible}" Margin="0,0,12,4">
                                        <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold"
                                                   Foreground="{Binding Color, Converter={StaticResource HexToBrush}}"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <ListBox x:Name="LogListBox" ItemsSource="{Binding Log.Entries}"
                         BorderBrush="#DDD" BorderThickness="1" Background="#FAFAFA"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" Foreground="{Binding Color, Converter={StaticResource HexToBrush}}"
                                       FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <GridSplitter Grid.Row="2" Style="{StaticResource HorizontalGridSplitterStyle}"/>

        <!-- 底部：左 CMD/回传 | 右 串口监控（可上下拖动调整高度） -->
        <Border Grid.Row="3" Padding="8" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                </Grid.ColumnDefinitions>

                <!-- 左半：协议命令 + 回传（一体，无分割条） -->
                <Grid Grid.Column="0" Margin="0,0,4,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="80"/>
                        </Grid.RowDefinitions>

                        <!-- 当前命令（命令码表全集） -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="当前命令" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Commands.Opcodes}"
                                      SelectedItem="{Binding Commands.SelectedOpcode}"
                                      DisplayMemberPath="DisplayLabel"/>
                        </Grid>

                        <!-- 常用 | 历史命令 | 保存为新命令 -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ItemsControl Grid.Column="0" ItemsSource="{Binding Commands.FavoriteOpcodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" Tag="{Binding}" Click="QuickCommand_Click"
                                                Padding="8,4" Margin="0,0,6,6" FontSize="11"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="历史命令" FontSize="11" Foreground="#555" VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <ComboBox Width="240" ItemsSource="{Binding Commands.SendHistory}"
                                          SelectedItem="{Binding Commands.SelectedHistoryItem}"
                                          DisplayMemberPath="DisplayLabel"
                                          ToolTip="选中后载入；可解析则还原 AT+/CMD，否则填入发送内容框"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="保存为新命令…"
                                    Command="{Binding Commands.SaveNewCommandCommand}"
                                    Padding="10,4" Margin="0,0,0,0" VerticalAlignment="Top"/>
                        </Grid>

                        <!-- 可编辑双帧（弱联动，统一行高与列宽） -->
                        <Border Grid.Row="2" Style="{StaticResource CmdPanelBorderStyle}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="108"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Commands.CmdPrefix}"
                                           Style="{StaticResource CmdPrefixLabelStyle}"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding Commands.TextBody, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CmdInputTextBoxStyle}"/>
                                <RadioButton Grid.Row="0" Grid.Column="2" Content="用此格式发送"
                                             Style="{StaticResource CmdWireRadioStyle}"
                                             IsChecked="{Binding Commands.IsTextWire}"
                                             GroupName="CmdWireFormat"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Commands.CmdBinaryPrefix}"
                                           Style="{StaticResource CmdPrefixLabelStyle}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding Commands.PayloadHex, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CmdInputTextBoxStyle}"
                                         ToolTip="Opcode + 参数字节，如 0x02 或 0x04 C2 00"/>
                                <RadioButton Grid.Row="2" Grid.Column="2" Content="用此格式发送"
                                             Style="{StaticResource CmdWireRadioStyle}"
                                             IsChecked="{Binding Commands.IsBinaryWire}"
                                             GroupName="CmdWireFormat"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Commands.BinaryFrameSizeLabel}"
                                           FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>

                        <!-- 发送内容（前） + 发送格式（后） -->
                        <Grid Grid.Row="3" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="发送内容" FontSize="12" Foreground="#555"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Commands.StatusText}" FontSize="11"
                                       Foreground="#555" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Grid.Row="4" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Commands.SendContentHex, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding Commands.IsSendContentReadOnly}"
                                     Style="{StaticResource CmdHexPreviewStyle}"/>
                            <Button Grid.Column="1" Content="发送" Command="{Binding Commands.SendCommand}"
                                    Padding="16,6" Margin="8,0,0,0" MinWidth="72" FontWeight="SemiBold"
                                    VerticalAlignment="Top"/>
                        </Grid>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="定时" VerticalAlignment="Center" Foreground="#555" FontSize="12"/>
                            <TextBox Width="56" Margin="6,0,4,0" Padding="4,2"
                                     Text="{Binding TimedSend.IntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding TimedSend.CanEditInterval}"
                                     VerticalAlignment="Center"
                                     ToolTip="间隔 100～3600000 毫秒"/>
                            <TextBlock Text="ms" VerticalAlignment="Center" Foreground="#555" FontSize="12" Margin="0,0,8,0"/>
                            <Button Content="{Binding TimedSend.ToggleButtonText}" Command="{Binding TimedSend.ToggleCommand}"
                                    Padding="12,4" MinWidth="56"
                                    ToolTip="按当前 AT+/CMD 帧循环发送；断开串口自动停止"/>
                            <TextBlock Text="{Binding TimedSend.StatusText}" VerticalAlignment="Center"
                                       Foreground="#666" FontSize="11" Margin="10,0,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="6" Margin="0,10,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="命令回传" FontWeight="SemiBold" FontSize="12" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="清空" Command="{Binding Ack.ClearCommand}"
                                    Padding="8,3" HorizontalAlignment="Stretch" VerticalAlignment="Center" MinWidth="52"/>
                        </Grid>

                        <Border Grid.Row="7" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1"
                                CornerRadius="3" Padding="6" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Ack.LatestSummary}" FontFamily="Consolas" FontSize="12"
                                       FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#1B5E20"/>
                        </Border>

                        <ListBox x:Name="AckListBox" Grid.Row="8" ItemsSource="{Binding Ack.Entries}"
                                 BorderBrush="#DDD" Background="#F5F5F5" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" FontFamily="Consolas" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#616161"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                        <Setter Property="Foreground" Value="#1B5E32"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                </Grid>

                <GridSplitter Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}"/>

                <!-- 右半：任意发送 + 串口监控 -->
                <DockPanel Grid.Column="2">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="任意发送" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding RawSend.RawSend, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="12" Padding="6,4" VerticalContentAlignment="Center"
                                 ToolTip="HEX 模式：空格分隔，支持 0x 前缀；否则按 UTF-8 文本发送"/>
                        <Button Grid.Column="2" Content="发送" Command="{Binding RawSend.SendCommand}"
                                Padding="14,4" Margin="8,0,12,0" MinWidth="56" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="3" Content="HEX 模式" IsChecked="{Binding RawSend.RawSendAsHex}"
                                  VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox Grid.Column="4" Content="末尾加换行 (0x0A)"
                                  IsChecked="{Binding RawSend.RawSendAppendNewline}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="串口监控" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="{Binding Traffic.DisplayModeLabel, StringFormat=显示: {0}}"
                                Command="{Binding Traffic.ToggleDisplayModeCommand}" Margin="12,0,0,0" Padding="10,4"
                                ToolTip="原始收发数据；每条报文（以换行结束）单独一行"/>
                        <Button Content="{Binding Traffic.PauseButtonText}" Command="{Binding Traffic.TogglePauseCommand}" Margin="8,0,0,0" Padding="10,4"/>
                        <CheckBox Content="自动滚动" IsChecked="{Binding Traffic.AutoScroll}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <Button Content="清空" Command="{Binding Traffic.ClearCommand}" Margin="8,0,0,0" Padding="10,4"/>
                        <Button Content="保存" Command="{Binding Traffic.SaveCommand}" Margin="6,0,0,0" Padding="10,4"/>
                    </StackPanel>
                    <ListBox x:Name="TrafficListBox" ItemsSource="{Binding Traffic.DisplayLines}"
                             FontFamily="Consolas" FontSize="12" BorderBrush="#DDD" Background="#FAFAFA"/>
                </DockPanel>
            </Grid>
        </Border>
        </Grid>
    </DockPanel>
</Window>
